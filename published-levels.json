/* Boyce Lab Genetic Epilepsy Landscape — custom theme overrides
   Aligns Material color tokens to the dashboard's purple palette. */

:root {
  --md-primary-fg-color:        #6d28d9;
  --md-primary-fg-color--light: #8b5cf6;
  --md-primary-fg-color--dark:  #5b21b6;
  --md-accent-fg-color:         #6d28d9;
  --md-accent-fg-color--transparent: rgba(109, 40, 217, 0.1);
}

[data-md-color-scheme="default"] {
  --md-default-bg-color: #f6f1e7;
  --md-default-fg-color: #0e1a2b;
  --md-typeset-a-color: #6d28d9;
}

[data-md-color-scheme="slate"] {
  --md-default-bg-color: #1a1625;
  --md-typeset-a-color: #b794f4;
}

/* Make the page feel a touch warmer in light mode */
[data-md-color-scheme="default"] .md-main {
  background: var(--md-default-bg-color);
}

/* Dashboard popout button (above iframe) */
.dashboard-popout {
  display: inline-flex;
  align-items: center;
  margin: 0.4em 0 1em;
  font-size: 0.95em;
}

/* Wrapper around iframe + fullscreen toggle */
.dashboard-wrapper {
  position: relative;
  width: 100%;
  margin: 1.5em 0;
  background: #f6f1e7;
  border: 1.5px solid #0e1a2b;
  border-radius: 4px;
  overflow: hidden;
}

[data-md-color-scheme="slate"] .dashboard-wrapper {
  border-color: #4a3868;
}

/* Iframe */
.dashboard-frame {
  width: 100%;
  height: 85vh;
  min-height: 800px;
  border: none;
  background: #f6f1e7;
  display: block;
}

/* Floating fullscreen toggle in the wrapper corner */
.dashboard-fullscreen-btn {
  position: absolute;
  top: 10px;
  right: 14px;
  z-index: 10;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  background: rgba(255, 255, 255, 0.92);
  color: #5b21b6;
  border: 1.5px solid #6d28d9;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  transition: all 0.12s;
}

.dashboard-fullscreen-btn:hover {
  background: #6d28d9;
  color: white;
}

.dashboard-fullscreen-btn .fs-label {
  letter-spacing: 0.04em;
}

/* When wrapper is fullscreen, fill the viewport */
.dashboard-wrapper:fullscreen,
.dashboard-wrapper:-webkit-full-screen {
  background: #f6f1e7;
  border: none;
  border-radius: 0;
  margin: 0;
  padding: 0;
}

.dashboard-wrapper:fullscreen .dashboard-frame,
.dashboard-wrapper:-webkit-full-screen .dashboard-frame {
  width: 100vw;
  height: 100vh;
  min-height: 100vh;
}

.dashboard-wrapper:fullscreen .dashboard-fullscreen-btn,
.dashboard-wrapper:-webkit-full-screen .dashboard-fullscreen-btn {
  /* Make the exit button more visible in fullscreen */
  background: #6d28d9;
  color: white;
}

/* Soften the default Material headings to match Fraunces in the dashboard */
.md-typeset h1,
.md-typeset h2 {
  font-family: 'Fraunces', Georgia, serif;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.md-typeset h1 {
  font-size: 2.2em;
  margin-bottom: 0.4em;
}

/* Header masthead refinement */
.md-header {
  background: linear-gradient(90deg, #5b21b6 0%, #6d28d9 100%);
  box-shadow: 0 0 0.2rem rgba(0,0,0,.1), 0 0.2rem 0.4rem rgba(0,0,0,.05);
}

/* Status badge component for inline use in markdown */
.status-badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 12px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78em;
  font-weight: 500;
  white-space: nowrap;
  margin-right: 4px;
}
.status-established {
  background: #f3eaff;
  color: #5b21b6;
  border: 1px solid #7c3aed;
}
.status-emerging {
  background: #faf5ff;
  color: #6d28d9;
  border: 1px solid #c4b5fd;
}
.status-background {
  background: #fafaf7;
  color: #6b7280;
  border: 1px solid #d4ccb8;
}

/* Quick-link callout cards on the home page */
.quick-links {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1em;
  margin: 1.5em 0;
}
.quick-link-card {
  display: block;
  padding: 18px 20px;
  border: 1.5px solid #0e1a2b;
  border-radius: 4px;
  background: white;
  text-decoration: none !important;
  color: #0e1a2b !important;
  transition: all 0.15s;
}
[data-md-color-scheme="slate"] .quick-link-card {
  background: #221b30;
  color: #e4dff0 !important;
  border-color: #4a3868;
}
.quick-link-card:hover {
  background: #6d28d9;
  color: white !important;
  border-color: #6d28d9;
  transform: translateY(-2px);
}
.quick-link-card .ql-title {
  font-family: 'Fraunces', Georgia, serif;
  font-weight: 600;
  font-size: 1.05em;
  margin-bottom: 4px;
}
.quick-link-card .ql-desc {
  font-size: 0.88em;
  opacity: 0.8;
}

/* Footer styling */
.md-footer-meta {
  background: #0e1a2b;
}

/* Definition list improvements */
.md-typeset dl dt {
  font-weight: 600;
  color: var(--md-primary-fg-color);
}

/* Code in admonitions reads better */
.md-typeset code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85em;
}

/* Tighter table padding */
.md-typeset table:not([class]) {
  font-size: 0.82em;
}
